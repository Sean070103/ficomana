# ─── Supabase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy name also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server writes, receipt resubmit uploads, automatic DB sync (required for production)
# Supabase Dashboard → Settings → API → service_role (keep secret, server-only)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site URL (production) ─────────────────────────────────────────────────────
# Used in rejection emails for "Upload New Receipt" deep links
NEXT_PUBLIC_SITE_URL=https://ficomana.studio

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Server-only — never use NEXT_PUBLIC_ prefix for the API key
# Resend Dashboard → API Keys → create key → paste here and on Vercel
RESEND_API_KEY=

# After verifying ficomana.studio in Resend Domains:
RESEND_FROM_EMAIL=FICO MANA Studio <bookings@ficomana.studio>
# Temporary sandbox only: FICO MANA Studio <onboarding@resend.dev>
# Or set RESEND_SANDBOX=true for local sends via onboarding@resend.dev

# ─── Production checklist ──────────────────────────────────────────────────────
# 1. Run lib/migrations/002_packages_and_booking_fields.sql
# 2. Run lib/migrations/003_drop_booking_notify_trigger.sql
# 3. Run lib/migrations/004_receipts_storage.sql
# 4. Run lib/migrations/005_bookings_rls.sql
# 5. Set SUPABASE_SERVICE_ROLE_KEY + NEXT_PUBLIC_SITE_URL=https://ficomana.studio on Vercel
# 6. Verify ficomana.studio in Resend → Domains, then set RESEND_API_KEY + RESEND_FROM_EMAIL and redeploy
# 7. Staff: GET /api/emails/health then POST {} to send a test email from bookings@ficomana.studio
