# ─── Supabase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy name also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server writes, receipt resubmit uploads, notifications without staff session
# Supabase Dashboard → Settings → API → service_role (keep secret, server-only)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site URL (production) ─────────────────────────────────────────────────────
# Used in rejection emails for "Upload New Receipt" deep links
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── Email (optional) ──────────────────────────────────────────────────────────
# Without this, emails are logged in admin but not delivered
# RESEND_API_KEY=

# ─── Production checklist ──────────────────────────────────────────────────────
# 1. Run lib/migrations/002_packages_and_booking_fields.sql
# 2. Run lib/migrations/003_drop_booking_notify_trigger.sql
# 3. Run lib/migrations/004_receipts_storage.sql
# 4. Run lib/migrations/005_bookings_rls.sql
# 5. Set SUPABASE_SERVICE_ROLE_KEY + NEXT_PUBLIC_SITE_URL on Vercel
# 6. Set RESEND_API_KEY on Vercel for live email delivery
